                Q(user__username__icontains=q)
                | Q(user__first_name__icontains=q)
                | Q(user__last_name__icontains=q)
                | Q(user__email__icontains=q)
                | Q(professional_license__icontains=q)
                | Q(phone__icontains=q)
            )

