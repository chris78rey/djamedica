<file path="templates/appointments/list.html">
{% extends "base.html" %}

{% block title %}Citas | Djamedica{% endblock %}

{% block content %}
    <h1 class="page-title">Citas</h1>

    <form method="get" class="filters">
        <div class="full">
            <label>Buscar</label>
            <input type="text" name="q" value="{{ filter_q }}" placeholder="Paciente, doctor, documento o motivo">
        </div>

        <div>
            <label>Estado</label>
            <select name="status">
                <option value="">Todos</option>
                {% for value, label in status_choices %}
                    <option value="{{ value }}" {% if filter_status == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label>Doctor</label>
            <select name="doctor_id">
                <option value="">Todos</option>
                {% for doctor in doctor_choices %}
                    <option value="{{ doctor.id }}" {% if filter_doctor_id == doctor.id|stringformat:"s" %}selected{% endif %}>
                        {{ doctor.user.get_full_name|default:doctor.user.username }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label>Especialidad</label>
            <select name="specialty_id">
                <option value="">Todas</option>
                {% for specialty in specialty_choices %}
                    <option value="{{ specialty.id }}" {% if filter_specialty_id == specialty.id|stringformat:"s" %}selected{% endif %}>
                        {{ specialty.name }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label>Desde</label>
            <input type="date" name="date_from" value="{{ filter_date_from }}">
        </div>

        <div>
            <label>Hasta</label>
            <input type="date" name="date_to" value="{{ filter_date_to }}">
        </div>

        <div class="actions">
            <button type="submit">Filtrar</button>
            <a href="{% url 'appointments:manage_list' %}" class="secondary">Limpiar</a>
        </div>
    </form>

    {% if request.user.is_superuser or request.user.role == "ADMIN" or request.user.role == "STAFF" %}
        <div class="actions">
            <a href="{% url 'appointments:create' %}">Nueva cita</a>
        </div>
    {% endif %}

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Paciente</th>
                <th>Doctor</th>
                <th>Especialidad</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Motivo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for item in items %}
                <tr>
                    <td>{{ item.id }}</td>
                    <td>{{ item.patient.full_name }}</td>
                    <td>{{ item.doctor.user.get_full_name|default:item.doctor.user.username }}</td>
                    <td>{{ item.specialty.name }}</td>
                    <td>{{ item.scheduled_at }}</td>
                    <td>{{ item.status }}</td>
                    <td>{{ item.reason|truncatechars:50 }}</td>
                    <td class="actions">
                        {% if request.user.is_superuser or request.user.role == "ADMIN" or request.user.role == "STAFF" %}
                            <a href="{% url 'appointments:edit' item.id %}">Editar</a>
                            <a href="{% url 'appointments:delete' item.id %}" class="danger">Eliminar</a>
                        {% else %}
                            <span class="muted">Solo lectura</span>
                        {% endif %}
                    </td>
                </tr>
            {% empty %}
                <tr>
                    <td colspan="8">No existen registros.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {% include "common/pagination.html" %}
{% endblock %}
</file>

