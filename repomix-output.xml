<file path="templates/base.html">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Djamedica{% endblock %}</title>
    <style>
        :root {
            --bg: #f4f7fb;
            --surface: #ffffff;
            --line: #e5e7eb;
            --text: #111827;
            --muted: #6b7280;
            --primary: #1d4ed8;
            --primary-dark: #1e3a8a;
            --success-bg: #ecfdf5;
            --success-text: #065f46;
            --warning-bg: #fffbeb;
            --warning-text: #92400e;
            --danger-bg: #fef2f2;
            --danger-text: #991b1b;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        nav {
            background: linear-gradient(90deg, var(--primary-dark), var(--primary));
            padding: 14px 20px;
        }

        .nav-wrap {
            max-width: 1240px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links, .nav-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        nav a, nav button {
            color: #fff;
            text-decoration: none;
            background: rgba(255,255,255,0.12);
            border: 0;
            border-radius: 8px;
            padding: 8px 12px;
            cursor: pointer;
            font-size: 14px;
        }

        nav form { margin: 0; }

        .container {
            max-width: 1240px;
            margin: 24px auto;
            padding: 0 16px;
        }

        .surface {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 22px;
        }

        .page-title {
            margin-top: 0;
            margin-bottom: 8px;
        }

        .muted {
            color: var(--muted);
        }

        .actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin: 16px 0;
        }

        .actions a,
        .actions button {
            text-decoration: none;
            border: 0;
            border-radius: 8px;
            padding: 10px 14px;
            cursor: pointer;
            background: var(--primary);
            color: #fff;
            font-size: 14px;
        }

        .actions .secondary {
            background: #6b7280;
        }

        .actions .danger {
            background: #dc2626;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 16px;
        }

        .card {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 12px;
            padding: 16px;
        }

        .card strong {
            display: block;
            margin-bottom: 8px;
        }

        .card .big {
            font-size: 28px;
            font-weight: bold;
        }

        .filters {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin: 18px 0;
        }

        .filters .full {
            grid-column: span 2;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
            background: #fff;
        }

        th, td {
            border: 1px solid var(--line);
            padding: 10px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #f9fafb;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            background: #fff;
        }

        .messages {
            margin-bottom: 16px;
        }

        .message {
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 10px;
        }

        .message.success {
            background: var(--success-bg);
            color: var(--success-text);
        }

        .message.warning {
            background: var(--warning-bg);
            color: var(--warning-text);
        }

        .message.error {
            background: var(--danger-bg);
            color: var(--danger-text);
        }

        .pagination {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
            margin-top: 18px;
        }

        .pagination a,
        .pagination span {
            border: 1px solid var(--line);
            background: #fff;
            padding: 8px 12px;
            border-radius: 8px;
            text-decoration: none;
            color: var(--text);
        }

        .pagination .current {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        .errorlist {
            color: #b91c1c;
            margin: 6px 0 0 0;
        }

        @media (max-width: 980px) {
            .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .filters { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 620px) {
            .grid { grid-template-columns: 1fr; }
            .filters { grid-template-columns: 1fr; }
            .filters .full { grid-column: span 1; }
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-wrap">
            <div class="nav-links">
                <a href="{% url 'home' %}">Inicio</a>
                <a href="{% url 'health' %}">Health</a>
                {% if request.user.is_authenticated %}
                    <a href="{% url 'panel' %}">Panel</a>
                    <a href="{% url 'users:manage_list' %}">Usuarios</a>
                    <a href="{% url 'specialties:manage_list' %}">Especialidades</a>
                    <a href="{% url 'patients:manage_list' %}">Pacientes</a>
                    <a href="{% url 'doctors:manage_list' %}">Doctores</a>
                    <a href="{% url 'appointments:manage_list' %}">Citas</a>
                {% endif %}
            </div>

            <div class="nav-actions">
                {% if request.user.is_authenticated %}
                    <span style="color:#fff;">{{ request.user }}</span>

                    {% if request.user.is_staff or request.user.is_superuser %}
                        <a href="/admin/">Admin</a>
                    {% endif %}

                    <form method="post" action="{% url 'logout' %}">
                        {% csrf_token %}
                        <button type="submit">Salir</button>
                    </form>
                {% else %}
                    <a href="{% url 'login' %}">Ingresar</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <div class="container">
        {% if messages %}
            <div class="messages">
                {% for message in messages %}
                    <div class="message {% if message.tags %}{{ message.tags }}{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="surface">
            {% block content %}{% endblock %}
        </div>
    </div>
</body>
</html>
</file>

<file path="apps/core/views.py">
from django.contrib.auth.decorators import login_required
from django.http import JsonResponse
from django.shortcuts import render

from apps.appointments.models import Appointment
from apps.doctors.models import Doctor
from apps.patients.models import Patient
from apps.specialties.models import Specialty
from apps.users.models import User


def home(request):
    return render(request, "core/home.html", {"project_name": "Djamedica"})


def health(request):
    return JsonResponse(
        {"status": "ok", "app": "djamedica", "framework": "django"}
    )


def dashboard(request):
    return JsonResponse(
        {
            "users": User.objects.count(),
            "specialties": Specialty.objects.count(),
            "patients": Patient.objects.count(),
            "doctors": Doctor.objects.count(),
            "appointments": Appointment.objects.count(),
        }
    )


@login_required
def panel(request):
    user = request.user

    appointments_qs = Appointment.objects.all()
    if getattr(user, "role", None) == "DOCTOR" and not user.is_superuser:
        appointments_qs = appointments_qs.filter(doctor__user=user)

    context = {
        "project_name": "Djamedica",
        "users_count": User.objects.count(),
        "specialties_count": Specialty.objects.count(),
        "patients_count": Patient.objects.count(),
        "doctors_count": Doctor.objects.count(),
        "appointments_count": appointments_qs.count(),
    }
    return render(request, "core/panel.html", context)
